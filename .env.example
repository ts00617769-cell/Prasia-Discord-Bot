# ==========================================
# 🤖 波拉西亞戰記 Discord Bot 環境變數設定檔範例
# ==========================================

# 1. Discord 機器人金鑰 (必填)
# 請至 Discord Developer Portal 申請並將你的 Token 貼在下方
DISCORD_TOKEN=your_discord_bot_token_here

# 2. NEXON Open API 金鑰 (選填 / 未來擴充保留)
# 如果未來原廠開放台版資料，請將 Nexon API Key 填入下方
NEXON_API_KEY=your_nexon_api_key_here